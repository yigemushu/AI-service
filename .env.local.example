# Optional. Leave unset to use local mock analysis mode.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional. Defaults to gpt-4.1-mini when unset.
OPENAI_MODEL=gpt-4.1-mini

# Optional speed controls.
OPENAI_FAST_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=18000
OPENAI_MAX_OUTPUT_TOKENS=800

# Required for /api/inbox in local network or production deployments.
# Use a random value and fill the same token in Settings -> Webhook Token and the browser extension.
INBOX_WEBHOOK_TOKEN=your_random_webhook_token_here
