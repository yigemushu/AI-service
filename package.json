{
  "name": "ai-service-workbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:stable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-dev.ps1",
    "dev:stable:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-dev.ps1 -StopExisting",
    "dev:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-local-dev.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3"
  }
}
